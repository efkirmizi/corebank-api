# Copy to .env and adjust. Never commit a real .env.

# Which config class to load: development | testing | production
APP_ENV=development

# --- Security ---
# Generate a strong value for production, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me
JWT_ACCESS_TOKEN_EXPIRES_HOURS=1

# --- Database ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change-me
DB_NAME=bank
DB_POOL_SIZE=5

# --- CORS ---
# Comma-separated allowlist of origins. Must not be "*" in production.
CORS_ORIGINS=*
